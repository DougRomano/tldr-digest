# ============================================================================
# TLDRDigest configuration. Copy to .env and fill in.
# ============================================================================

# --- Yahoo Mail IMAP --------------------------------------------------------
# Generate an app password at https://login.yahoo.com/account/security/app-passwords
YAHOO_USER=martinguitarplayer2000@yahoo.com
YAHOO_APP_PASSWORD=xxxxxxxxxxxxxxxx

# --- Postgres ---------------------------------------------------------------
# Driver MUST be postgresql+asyncpg. The database MUST have the `pgvector`
# extension available (see DEPLOY.md). Format:
#   postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
#
# Pointing at your Unraid Postgres — use the server's LAN IP (or hostname):
DATABASE_URL=postgresql+asyncpg://tldr:tldr@192.168.1.10:5432/tldr
#
# If the app container runs ON the same Unraid box AND on the same Docker
# network as Postgres, you can use the container name instead of the IP:
#   DATABASE_URL=postgresql+asyncpg://tldr:tldr@postgres:5432/tldr
#
# Mac-local dev with `docker compose --profile local-db up`:
#   DATABASE_URL=postgresql+asyncpg://tldr:tldr@localhost:5433/tldr

# --- LLM providers (at least one) -------------------------------------------
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
# Optional — real embeddings via Voyage; without it a hash-fallback is used.
VOYAGE_API_KEY=

OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=mxbai-embed-large

# Provider used when no setting row exists yet: claude | ollama
DEFAULT_LLM_PROVIDER=claude

# --- Reports output ---------------------------------------------------------
# In Docker this is fixed to /reports (see docker-compose.yml). Set the HOST
# path that gets mounted there — e.g. an Unraid share:
REPORTS_HOST_DIR=/mnt/user/appdata/tldr-digest/reports
# For Mac-local (non-Docker) runs, REPORTS_DIR is used directly:
REPORTS_DIR=/Users/douglasromano/Documents/Claude/Projects/Branding

# --- Web --------------------------------------------------------------------
WEB_HOST=0.0.0.0
WEB_PORT=8080
